# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Necessária a partir da Fase F (Portal do Cliente) — usada apenas em
# Server Actions administrativas (lib/supabase/admin.ts), NUNCA no navegador.
# Fica em Project Settings > API > service_role (NÃO é a chave anon).
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta

# Central de Comunicação (Fase 9) — Meta WhatsApp Cloud API.
# Todas opcionais: sem elas, o webhook ainda recebe e grava mensagens
# normalmente, só o ENVIO automático fica desligado (ver whatsapp.api.ts).
WHATSAPP_VERIFY_TOKEN=defina-um-token-qualquer-para-o-handshake-da-meta
WHATSAPP_APP_SECRET=app-secret-do-app-da-meta-para-validar-assinatura-do-webhook
WHATSAPP_ACCESS_TOKEN=token-de-acesso-permanente-da-cloud-api
WHATSAPP_PHONE_NUMBER_ID=id-do-numero-de-telefone-no-business-manager
# Só quando true o envio de mensagem de fato chama a API da Meta:
WHATSAPP_INTEGRACAO_ATIVA=false
